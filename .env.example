# World Explorer - Environment Variables Template
# 
# IMPORTANT: Copy this file to .env and fill in your API keys
# NEVER commit .env to Git - it's already in .gitignore
#
# For Vercel deployment:
# 1. Do NOT upload .env to GitHub
# 2. Set these variables in Vercel dashboard: Settings → Environment Variables
# 3. Vercel will inject them at build time

# Mapillary API Token (for street-level imagery)
# Get your token at: https://www.mapillary.com/app/settings/developers
# Format: MLY|...
VITE_MAPILLARY_TOKEN=

# Cesium Ion Access Token (for 3D tiles and imagery)
# Get your token at: https://ion.cesium.com/
# Format: eyJ...
VITE_CESIUM_TOKEN=
